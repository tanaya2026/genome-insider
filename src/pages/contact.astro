---
import BaseLayout from '../layouts/BaseLayout.astro';

const FORMSPREE_ENDPOINT = 'https://formspree.io/f/xqerkdag';
---

<BaseLayout title="Contact" description="Get in touch with Genome Insider.">
  <section class="wrap contact-page">
    <span class="eyebrow">Contact</span>

    <h1 class="contact-title">Get in touch</h1>

    <p class="contact-intro">
      Questions, corrections, collaboration ideas, or simply want to discuss
      genomics, bioinformatics, or clinical research? I'd love to hear from you.
    </p>

    <form
      class="contact-form"
      action={FORMSPREE_ENDPOINT}
      method="POST"
    >
      <!-- Redirect after successful submission -->
      <input
        type="hidden"
        name="_next"
        value="https://genome-insider.vercel.app/contact-success"

      <!-- Email subject -->
      <input
        type="hidden"
        name="_subject"
        value="New message from Genome Insider"
      />

      <label class="field">
        <span>Name</span>
        <input
          type="text"
          name="name"
          required
          autocomplete="name"
        />
      </label>

      <label class="field">
        <span>Email</span>
        <input
          type="email"
          name="email"
          required
          autocomplete="email"
        />
      </label>

      <label class="field">
        <span>Message</span>
        <textarea
          name="message"
          rows="6"
          required
        ></textarea>
      </label>

      <button type="submit" class="btn">
        Send Message
      </button>
    </form>
  </section>
</BaseLayout>

<style>
  .contact-page {
    max-width: 620px;
    padding-block: clamp(2.5rem, 5vw, 4rem);
  }

  .contact-title {
    font-size: clamp(2.2rem, 5vw, 3rem);
    margin: 0.3rem 0 0.6rem;
  }

  .contact-intro {
    color: var(--color-text-muted);
    margin-bottom: 2.25rem;
    line-height: 1.6;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    font-size: 0.9rem;
    font-weight: 500;
  }

  input,
  textarea {
    font-family: var(--font-body);
    font-size: 0.98rem;
    padding: 0.8rem 1rem;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-border);
    background: var(--color-bg-elevated);
    color: var(--color-text);
    resize: vertical;
  }

  input:focus,
  textarea:focus {
    outline: none;
    border-color: var(--color-accent);
  }

  .btn {
    align-self: flex-start;
    border: 1px solid var(--color-accent);
  }
</style>