---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import TopicCard from '../components/TopicCard.astro';

const allArticles = (await getCollection('articles', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const featured = allArticles.filter((a) => a.data.featured).slice(0, 4);
const fallback = featured.length ? featured : allArticles.slice(0, 4);

const topics = [
  { emoji: '📊', name: 'AI and ML', href: '/articles/ai-and-ml' },
  { emoji: '🧫', name: 'Genomics', href: '/articles/genomics' },
  { emoji: '🦠', name: 'Immunology', href: '/articles/immunology' },
  { emoji: '🔬', name: 'Clinical Research', href: '/articles/clinical-research' },
  { emoji: '🧬', name: 'Bioinformatics', href: '/articles/bioinformatics' },
  { emoji: '🎗️', name: 'Cancer Biology', href: '/articles/cancer-biology' }
];

const countFor = (name: string) =>
  allArticles.filter((a) => a.data.categories.includes(name)).length;
---

<BaseLayout title="Genome Insider">
  <section class="hero">
    <div class="wrap hero-inner">
      <span class="eyebrow">A scientific publication</span>
      <h1 class="hero-title">Genome Insider</h1>
      <p class="hero-tagline">Exploring biology through computation,<br />data, and discovery.</p>
      <a href="/articles" class="btn">Explore Articles</a>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <h2 class="section-title">Featured Articles</h2>
      <div class="featured-grid">
        {fallback.map((article, i) => (
          <ArticleCard
            title={article.data.title}
            description={article.data.description}
            categories={article.data.categories}
            readingTime={article.data.readingTime}
            slug={article.slug}
            large={i === 0}
          />
        ))}
      </div>
      {allArticles.length === 0 && (
        <p class="empty-note">
          No articles published yet — add your first entry under <code>src/content/articles/</code>.
        </p>
      )}
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <h2 class="section-title">Topics</h2>
      <div class="topics-grid">
        {topics.map((t) => (
          <TopicCard emoji={t.emoji} name={t.name} href={t.href} count={countFor(t.name)} />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding-block: clamp(4rem, 12vw, 7.5rem);
    text-align: center;
    background:
      radial-gradient(ellipse at top, var(--color-accent-soft) 0%, transparent 60%);
  }

  .hero-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.1rem;
  }

  .hero-title {
    font-size: clamp(2.75rem, 7vw, 4.5rem);
    letter-spacing: -0.01em;
    margin: 0;
  }

  .hero-tagline {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(1.1rem, 2vw, 1.4rem);
    color: var(--color-text-muted);
    line-height: 1.5;
    margin: 0 0 0.75rem;
  }

  .section {
    padding-block: clamp(2.5rem, 5vw, 4rem);
  }

  .section-title {
    font-size: 1.9rem;
    margin-bottom: 1.75rem;
  }

  .featured-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .featured-grid > :global(a:first-child) {
    grid-column: span 2;
  }

  .topics-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 1.25rem;
  }

  .empty-note {
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }

  .empty-note code {
    background: var(--color-code-bg);
    padding: 0.1em 0.4em;
    border-radius: var(--radius-sm);
  }

  @media (max-width: 900px) {
    .topics-grid { grid-template-columns: repeat(3, 1fr); }
  }

  @media (max-width: 700px) {
    .featured-grid { grid-template-columns: 1fr; }
    .featured-grid > :global(a:first-child) { grid-column: span 1; }
  }

  @media (max-width: 560px) {
    .topics-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
