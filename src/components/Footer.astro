---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="wrap footer-inner">
    <p class="footer-tagline">Exploring biology through computation, data, and discovery.</p>
    <p class="footer-meta">© {year} Genome Insider. Written and maintained by Tanaya Datar.</p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    margin-top: 5rem;
    padding-block: 2.5rem;
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .footer-tagline {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--color-text-muted);
    margin: 0;
  }

  .footer-meta {
    font-size: 0.82rem;
    color: var(--color-text-muted);
    margin: 0;
  }
</style>
