---
interface Props {
  title: string;
  description: string;
  categories: string[];
  readingTime: number;
  slug: string;
  large?: boolean;
}

const { title, description, categories, readingTime, slug, large = false } = Astro.props;
---

<a href={`/articles/${slug}`} class:list={['article-card', { large }]}>
  <div class="categories">
    {categories.map((category) => (
      <span class="eyebrow">{category}</span>
    ))}
  </div>

  <h3 class="card-title">{title}</h3>
  <p class="card-desc">{description}</p>
  <span class="card-meta">{readingTime} min read</span>
</a>

<style>
  .article-card {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding: 1.75rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg-elevated);
    transition: transform 0.18s ease, border-color 0.18s ease, box-shadow 0.18s ease;
    height: 100%;
  }

  .article-card:hover {
    transform: translateY(-3px);
    border-color: var(--color-accent);
    box-shadow: 0 8px 24px -12px rgba(0, 0, 0, 0.18);
  }

  .categories {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .card-title {
    font-size: 1.35rem;
    margin: 0;
  }

  .article-card.large .card-title {
    font-size: 1.7rem;
  }

  .card-desc {
    color: var(--color-text-muted);
    font-size: 0.94rem;
    margin: 0;
    flex-grow: 1;
  }

  .card-meta {
    font-size: 0.78rem;
    color: var(--color-text-muted);
    letter-spacing: 0.02em;
  }
</style>